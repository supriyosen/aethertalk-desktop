{
  "name": "aethertalk-desktop",
  "private": true,
  "version": "0.0.0",
  "author": "Arya Sen",
  "description": "Desktop build and packaging repo for the local-first AetherTalk app.",
  "main": "electron/main.mjs",
  "productName": "AetherTalk",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n \"web,api\" -c \"magenta,cyan\" \"vite\" \"tsx watch server/index.ts\"",
    "dev:web": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc -b && tsc -p tsconfig.server.json && vite build",
    "build:icons": "node scripts/build-icons.mjs",
    "desktop": "electron .",
    "desktop:build": "npm run build && npm run build:icons && electron-builder --mac dmg zip",
    "desktop:dev": "concurrently -k -n \"web,api,electron\" -c \"magenta,cyan,yellow\" \"vite\" \"tsx watch server/index.ts\" \"wait-on tcp:5173 tcp:8787 && electron .\"",
    "lint": "eslint .",
    "launch": "node scripts/launch-aethertalk.mjs",
    "preview": "vite preview",
    "start": "node dist-server/index.js",
    "stop:app": "node scripts/stop-aethertalk.mjs"
  },
  "dependencies": {
    "express": "^5.1.0",
    "jspdf": "^4.2.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.aryasen.aethertalk",
    "productName": "AetherTalk",
    "files": [
      "dist/**/*",
      "dist-server/**/*",
      "electron/**/*",
      "package.json",
      "public/app-icon.svg"
    ],
    "directories": {
      "buildResources": "build"
    },
    "mac": {
      "artifactName": "AetherTalk-${version}-${arch}.${ext}",
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    }
  }
}
